# =====================================================================
# .env.example — dkm-learning-hub
# Copier vers .env (jamais committé) et remplir avec de VRAIES valeurs.
# Aucune valeur réelle ne doit apparaître dans ce fichier d'exemple.
#
# Note : ces variables sont surtout configurées comme credentials DANS n8n.
# Ce fichier documente les noms attendus.
# =====================================================================

# --- Supabase ---
# URL du projet Supabase (ex: https://xxxx.supabase.co)
SUPABASE_URL=
# Clé service role (côté serveur / n8n uniquement — JAMAIS côté client)
SUPABASE_SERVICE_ROLE_KEY=
# Clé publishable/anon (lecture côté client si besoin)
SUPABASE_ANON_KEY=

# --- Anthropic (Claude Haiku pour la structuration) ---
ANTHROPIC_API_KEY=
# Modèle utilisé pour la structuration
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# --- Telegram (capture / notification) ---
TELEGRAM_BOT_TOKEN=
# Chat/topic de notification de Dennis
TELEGRAM_DENNIS_CHAT_ID=

# --- Notion (miroir, optionnel V1) ---
NOTION_API_KEY=
NOTION_DATABASE_ID=

# --- n8n (si appels API) ---
N8N_BASE_URL=
N8N_API_KEY=
